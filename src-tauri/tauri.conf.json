{
  "productName": "DiffSync",
  "version": "4.2.0",
  "identifier": "com.diff.sync.desktop",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "DiffSync",
        "width": 1200,
        "height": 750,
        "minWidth": 1200,
        "minHeight": 550,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
